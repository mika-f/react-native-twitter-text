{
  "name": "@natsuneko-laboratory/react-native-twitter-text",
  "version": "0.1.0",
  "description": "A React Native plugin that provides Twitter's twitter-text parsing library via native Objective-C and Java implementations. Especially fast for CJK text compared to the JavaScript implementation.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "react-native": "./lib/module/index.js",
      "default": "./lib/module/index.js"
    },
    "./app.plugin.js": "./app.plugin.js",
    "./react-native.config.js": "./react-native.config.js",
    "./package.json": "./package.json"
  },
  "react-native": "./src/index.tsx",
  "expo": {
    "autolinking": {
      "nativeModules": true
    }
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "app.plugin.js",
    "LICENSE-TWITTER-TEXT",
    "react-native.config.js",
    "submodules/twitter-text/objc/lib/**/*",
    "submodules/twitter-text/objc/ThirdParty/IFUnicodeURL/IFUnicodeURL/**/*",
    "submodules/twitter-text/objc/ThirdParty/IFUnicodeURL/Resources/**/*",
    "submodules/twitter-text/objc/ThirdParty/IFUnicodeURL/IFUnicodeURL-LICENSE.txt",
    "submodules/twitter-text/objc/ThirdParty/IFUnicodeURL/README.txt",
    "submodules/twitter-text/objc/resources/**/*",
    "submodules/twitter-text/objc/twitter-text.podspec",
    "submodules/twitter-text/objc/LICENSE",
    "submodules/twitter-text/java/src/main/**/*",
    "submodules/twitter-text/java/LICENSE",
    "submodules/twitter-text/java/pom.xml",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-twitter-text-example",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "release": "release-it --only-version",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mika-f/react-native-twitter-text.git"
  },
  "author": "Kanon Mochizuki <me@natsuneko.cat> (https://github.com/mika-f)",
  "license": "(MIT AND Apache-2.0 AND BSD-2-Clause)",
  "bugs": {
    "url": "https://github.com/mika-f/react-native-twitter-text/issues"
  },
  "homepage": "https://github.com/mika-f/react-native-twitter-text#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.12",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^2.8.8",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-builder-bob": "^0.40.18",
    "release-it": "^19.0.4",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "TwitterTextSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.natsuneko.twittertext"
    }
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "release-it",
      "eslint",
      "jest"
    ],
    "version": "0.57.2"
  }
}
